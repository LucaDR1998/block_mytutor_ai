{{!
    @template block_mytutor_ai/chat

    Template for the MyTutor AI chat interface container.

    Context variables required for this template:
    * courseid - The course ID
    * uniqid - Unique DOM id
    * chatplaceholder - Placeholder text for the input
    * sendbutton - Label for the send button
    * isready - Whether backend chat is available
    * chatbgcolor - Optional chat background colour
    * usermsgcolor - Optional user message background colour
    * assistantmsgcolor - Optional assistant message background colour
    * tutoravatarurl - Optional tutor avatar image URL
    * hastutoravatar - Whether a tutor avatar is configured

    Example context (json):
    {
        "uniqid": "block-mytutor-ai-67d5f2eecf857",
        "courseid": 2,
        "chatplaceholder": "Ask a question about this course...",
        "sendbutton": "Send",
        "isready": true,
        "chatbgcolor": "#ffffff",
        "usermsgcolor": "#0f6cbf",
        "assistantmsgcolor": "#f7f9fc",
        "tutoravatarurl": "",
        "hastutoravatar": false
    }
}}
<div id="{{uniqid}}"
     class="block-mytutor-ai-chat"
     data-region="mytutor-ai-chat"
     data-courseid="{{courseid}}"
     data-assistant-label="{{assistantlabel}}"
     data-user-label="{{userlabel}}"
     data-thinking-text="{{thinkingtext}}"
     data-error-text="{{errortext}}"
     {{#hastutoravatar}}data-tutor-avatar="{{tutoravatarurl}}"{{/hastutoravatar}}
     style="{{#chatbgcolor}}--mytutor-chat-bg: {{chatbgcolor}};{{/chatbgcolor}} {{#usermsgcolor}}--mytutor-user-bg: {{usermsgcolor}};{{/usermsgcolor}} {{#assistantmsgcolor}}--mytutor-assistant-bg: {{assistantmsgcolor}};{{/assistantmsgcolor}}">
    {{#isready}}
        {{#hastutoravatar}}
        <div class="mytutor-ai-header">
            <img class="mytutor-ai-header-avatar"
                 src="{{tutoravatarurl}}"
                 alt="{{assistantlabel}}" />
            <span class="mytutor-ai-header-name">{{assistantlabel}}</span>
        </div>
        {{/hastutoravatar}}
        <div data-region="mytutor-ai-messages" class="mytutor-ai-messages">
            <div data-region="mytutor-ai-empty" class="mytutor-ai-empty">
                {{emptyconversation}}
            </div>
        </div>
        <div data-region="mytutor-ai-input" class="mytutor-ai-input">
            <textarea data-action="mytutor-ai-question"
                      class="form-control"
                      placeholder="{{chatplaceholder}}"
                      rows="2"></textarea>
            <button data-action="mytutor-ai-send"
                    class="btn btn-primary mt-2 align-self-end">
                {{sendbutton}}
            </button>
        </div>
    {{/isready}}

    {{^isready}}
        <div class="alert alert-warning mb-0">
            {{{unavailablemessagehtml}}}
        </div>
    {{/isready}}
</div>
