{{!
    @template block_mytutor_ai/chat

    Template for the MyTutor AI chat interface container.

    Context variables required for this template:
    * courseid - The course ID
    * uniqid - Unique DOM id
    * chatplaceholder - Placeholder text for the input
    * sendbutton - Label for the send button
    * isready - Whether backend chat is available
    * chatbgcolor - Optional chat background colour
    * usermsgcolor - Optional user message background colour
    * assistantmsgcolor - Optional assistant message background colour
    * tutoravatarurl - Optional tutor avatar image URL
    * hastutoravatar - Whether a tutor avatar is configured

    Example context (json):
    {
        "uniqid": "block-mytutor-ai-67d5f2eecf857",
        "courseid": 2,
        "chatplaceholder": "Ask a question about this course...",
        "sendbutton": "Send",
        "isready": true,
        "chatbgcolor": "#ffffff",
        "usermsgcolor": "#0f6cbf",
        "assistantmsgcolor": "#f7f9fc",
        "tutoravatarurl": "",
        "hastutoravatar": false,
        "accentcolor": "",
        "tutorcaption": "",
        "hastutorcaption": false,
        "hasdisclaimer": false,
        "disclaimer": "",
        "hasquickreplies": false,
        "quickreplies": []
    }
}}
<div id="{{uniqid}}"
     class="block-mytutor-ai-chat"
     data-region="mytutor-ai-chat"
     data-courseid="{{courseid}}"
     data-assistant-label="{{assistantlabel}}"
     data-user-label="{{userlabel}}"
     data-thinking-text="{{thinkingtext}}"
     data-error-text="{{errortext}}"
     {{#hastutoravatar}}data-tutor-avatar="{{tutoravatarurl}}"{{/hastutoravatar}}
     style="{{#chatbgcolor}}--mytutor-chat-bg: {{chatbgcolor}};{{/chatbgcolor}} {{#usermsgcolor}}--mytutor-user-bg: {{usermsgcolor}};{{/usermsgcolor}} {{#assistantmsgcolor}}--mytutor-assistant-bg: {{assistantmsgcolor}};{{/assistantmsgcolor}} {{#accentcolor}}--mytutor-accent: {{accentcolor}};{{/accentcolor}} {{#chattextcolor}}--mytutor-chat-text: {{chattextcolor}};{{/chattextcolor}}">
    {{#isready}}
        {{#hastutoravatar}}
        <div class="mytutor-ai-header">
            <img class="mytutor-ai-header-avatar"
                 src="{{tutoravatarurl}}"
                 alt="{{assistantlabel}}" />
            <div class="mytutor-ai-header-info">
                <span class="mytutor-ai-header-name">{{assistantlabel}}</span>
                {{#hastutorcaption}}
                <span class="mytutor-ai-header-caption">{{tutorcaption}}</span>
                {{/hastutorcaption}}
            </div>
        </div>
        {{/hastutoravatar}}
        <div data-region="mytutor-ai-messages" class="mytutor-ai-messages">
            <div data-region="mytutor-ai-empty" class="mytutor-ai-empty">
                {{emptyconversation}}
                {{#hasquickreplies}}
                <div class="mytutor-ai-quick-replies" data-region="mytutor-ai-quick-replies">
                    {{#quickreplies}}
                    <button type="button" class="mytutor-ai-quick-reply" data-action="mytutor-ai-quick-reply">{{text}}</button>
                    {{/quickreplies}}
                </div>
                {{/hasquickreplies}}
            </div>
        </div>
        <div data-region="mytutor-ai-input" class="mytutor-ai-input">
            <div class="mytutor-ai-composer">
                <textarea data-action="mytutor-ai-question"
                          class="form-control mytutor-ai-composer-textarea"
                          placeholder="{{chatplaceholder}}"
                          rows="3"></textarea>
                <div class="mytutor-ai-composer-actions">
                    <button data-action="mytutor-ai-send"
                            class="mytutor-ai-send-btn"
                            aria-label="{{sendbutton}}"
                            title="{{sendbutton}}">
                        <span class="mytutor-ai-send-btn-icon" aria-hidden="true">
                            <svg viewBox="0 0 20 20" focusable="false">
                                <path d="M10 14V6"></path>
                                <path d="M6.5 9.5L10 6L13.5 9.5"></path>
                            </svg>
                        </span>
                    </button>
                </div>
            </div>
        </div>
        {{#hasdisclaimer}}
        <div class="mytutor-ai-disclaimer">
            {{{disclaimer}}}
        </div>
        {{/hasdisclaimer}}
    {{/isready}}

    {{^isready}}
        <div class="alert alert-warning mb-0">
            {{{unavailablemessagehtml}}}
        </div>
    {{/isready}}
</div>
